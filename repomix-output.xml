                className="text-cosmic-muted hover:text-cosmic-text transition-colors text-lg font-bold"
              >✕</button>
            </div>

            {/* Chat Messages */}
            <div className="flex-1 overflow-y-auto px-3 py-2 space-y-2" style={{ maxHeight: 320, minHeight: 200 }}>
              {chatMessages.length === 0 && (
                <div className="text-center py-6">
                  <div className="text-4xl mb-2">💡</div>
                  <p className="text-cosmic-muted text-xs">Ask anything about the acronyms you're studying!</p>
                  <div className="mt-3 space-y-1">
                    {['What does RAM stand for?', 'Explain HTTP vs HTTPS', 'What is DNS?'].map((suggestion, i) => (
                      <button
                        key={i}
                        onClick={() => { setChatInput(suggestion); }}
                        className="block w-full text-left text-xs px-3 py-1.5 rounded-xl bg-cosmic-surface/80 text-cosmic-text hover:bg-baby-blue/30 transition-colors border border-cosmic-surface"
