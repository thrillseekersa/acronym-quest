<file path="legacy/style.css">
:root {
    --primary: #0ea5e9;
    --primary-hover: #0284c7;
    --bg-color: #fefce8;
    --card-bg: #ffffff;
    --text-main: #111827;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --success: #10b981;
    --danger: #ef4444;
    --radius: 16px;
    --shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
}

body {
    background-color: var(--bg-color);
    color: var(--text-main);
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem;
}

.app-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
}

.hidden {
    display: none !important;
}

/* Animations */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.view {
    animation: fadeIn 0.4s ease-out forwards;
}

/* Typography */
h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
}

h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
}

p {
    color: var(--text-muted);
    line-height: 1.5;
}

/* Card System */
.card {
    background: var(--card-bg);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    border: 1px solid rgba(255,255,255,0.5);
}

/* Setup & Login Cards */
.setup-card, .login-card {
    max-width: 500px;
    margin: 4rem auto;
    text-align: center;
}

.icon-wrapper {
    background: #e0f2fe;
    color: var(--primary);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem auto;
}

.icon-wrapper svg {
    width: 32px;
    height: 32px;
}

/* Forms */
.form-group {
    margin-bottom: 1.5rem;
    text-align: left;
}

label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text-main);
}

input[type="text"],
textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.2s;
    background: #f9fafb;
}

input[type="text"]:focus,
textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
    background: white;
}

/* Role Selector */
.role-selector {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
}

.role-option {
    flex: 1;
    cursor: pointer;
    margin-bottom: 0;
}

.role-option input {
    display: none;
}

.role-btn {
    display: block;
    text-align: center;
    padding: 0.75rem;
    background: #f9fafb;
    border: 2px solid var(--border);
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s;
    color: var(--text-muted);
}

.role-option input:checked + .role-btn {
    background: #e0f2fe;
    border-color: var(--primary);
    color: var(--primary);
}

/* Toggle Switch */
.toggle-group {
    margin-bottom: 1.5rem;
    background: #f9fafb;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
}

.toggle-control {
    display: flex;
    align-items: center;
    cursor: pointer;
}

.toggle-control input {
    display: none;
}

.control {
    width: 44px;
    height: 24px;
    background: var(--border);
    border-radius: 12px;
    position: relative;
    transition: background 0.3s;
    margin-right: 12px;
}

.control::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%;
    top: 2px;
    left: 2px;
    transition: transform 0.3s cubic-bezier(0.4, 0.0, 0.2, 1);
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
}

.toggle-control input:checked + .control {
    background: var(--primary);
}

.toggle-control input:checked + .control::after {
    transform: translateX(20px);
}

.label-text {
    font-weight: 500;
}

/* Buttons */
.btn-primary {
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 6px -1px rgba(14, 165, 233, 0.2);
}

.btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
}

.btn-secondary {
    background: white;
    color: var(--text-main);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-secondary:hover {
    background: #f9fafb;
    border-color: #d1d5db;
}

.w-full {
    width: 100%;
}

/* Dashboard Layout */
.dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
}

.subtitle {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 0.25rem;
}

/* Leaderboard */
.points-badge {
    background: #fef08a; /* yellow-200 */
    color: #854d0e; /* yellow-800 */
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    vertical-align: middle;
    margin-left: 0.5rem;
    font-weight: 700;
}

.leaderboard-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.leaderboard-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #f9fafb;
    border-radius: 8px;
    font-weight: 500;
}

.leaderboard-item:nth-child(1) {
    background: #fef9c3; /* yellow-100 */
    border: 1px solid #fde047;
}

.leaderboard-item:nth-child(2) {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
}

.leaderboard-item:nth-child(3) {
    background: #ffedd5; /* orange-100 */
    border: 1px solid #fed7aa;
}

.btn-reviewed {
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
}

.btn-reviewed:hover {
    background: var(--primary-hover);
}

.btn-reviewed:disabled {
    background: var(--success);
    cursor: default;
    opacity: 0.9;
}

/* AI Revision feature */
.btn-ai {
    margin-top: 0.75rem;
    margin-left: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    background: #8b5cf6; /* purple-500 */
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
}

.btn-ai:hover {
    background: #7c3aed; /* purple-600 */
}

.btn-ai:disabled {
    background: #c4b5fd; /* purple-300 */
    cursor: wait;
}

.ai-challenge {
    margin-top: 1rem;
    padding: 1rem;
    background: #fdf4ff; /* fuchsia-50 */
    border: 1px solid #e879f9; /* fuchsia-400 */
    border-radius: 8px;
    animation: fadeIn 0.4s ease-out;
}

.ai-challenge h4 {
    color: #701a75; /* fuchsia-900 */
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.ai-challenge ul {
    margin-left: 1.5rem;
    font-size: 0.875rem;
    color: #86198f; /* fuchsia-800 */
}

.ai-challenge li {
    margin-bottom: 0.5rem;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.spinning {
    animation: spin 1s linear infinite;
}

/* Worksheet feature */
.btn-worksheet {
    margin-top: 0.75rem;
    margin-left: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    background: white;
    color: #0369a1; /* sky-700 */
    border: 1px solid #7dd3fc; /* sky-300 */
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
}

.btn-worksheet:hover {
    background: #f0f9ff;
    border-color: #38bdf8;
}

.btn-worksheet:disabled {
    background: #e0f2fe;
    color: #7dd3fc;
    cursor: wait;
    border-color: #bae6fd;
}

.worksheet-container {
    margin-top: 1.5rem;
    padding: 2rem;
    background: white;
    border-radius: 4px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border-left: 3px double #f87171; /* red margin line */
    background-image: linear-gradient(transparent 95%, #bae6fd 95%);
    background-size: 100% 2em; /* Ruled paper lines */
    line-height: 2em;
    animation: fadeIn 0.5s ease-out;
}

.worksheet-header {
    text-align: center;
    margin-bottom: 2rem;
    border-bottom: 2px solid #333;
    padding-bottom: 1rem;
    background: white; /* overlay on ruled lines */
}

.worksheet-header h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
}

.worksheet-header p {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.25rem;
}

.worksheet-q {
    font-weight: 600;
    color: #111827;
    margin-top: 1rem;
    background: white;
    display: table;
    padding-right: 1rem;
}

.worksheet-empty-space {
    height: 4em; /* 2 lines of empty space */
}

.header-actions {
    display: flex;
    gap: 1rem;
}

.dashboard-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
}

/* Role-based visibility */
.student-view .dashboard-grid {
    grid-template-columns: 1fr;
}
.student-view .teacher-only {
    display: none !important;
}

@media (max-width: 768px) {
    .dashboard-grid {
        grid-template-columns: 1fr;
    }
}

.date-display {
    font-weight: 500;
    color: var(--primary);
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
}

/* History List */
.history-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: 500px;
    overflow-y: auto;
    padding-right: 0.5rem;
}

.history-item {
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #f9fafb;
    transition: transform 0.2s;
}

.history-item:hover {
    transform: translateX(4px);
    border-color: #d1d5db;
}

.history-date {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
}

.history-status {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.status-work {
    background: #d1fae5;
    color: #065f46;
}

.status-no-work {
    background: #fee2e2;
    color: #991b1b;
}

.history-pages {
    font-weight: 500;
    margin-bottom: 0.25rem;
}

.history-notes {
    font-size: 0.875rem;
    color: var(--text-muted);
}

.empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
}

/* Modal Styles */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    width: 90%;
    max-width: 600px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: var(--radius);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    animation: fadeIn 0.3s ease-out;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
}

.modal-header h2 {
    margin: 0;
    font-size: 1.25rem;
}

.close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-muted);
    transition: color 0.2s;
}

.close-btn:hover {
    color: var(--text-main);
}

.modal-body {
    padding: 2rem;
}

.mb-4 { margin-bottom: 1rem; }
.mt-4 { margin-top: 1rem; }
.py-8 { padding-top: 2rem; padding-bottom: 2rem; }
.text-center { text-align: center; }

/* Spinner */
.spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #f3f3f3;
    border-top: 4px solid var(--primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto;
}

/* Generated Quiz Styles */
.quiz-question {
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #f9fafb;
    border: 1px solid var(--border);
    border-radius: 8px;
}
.quiz-question h4 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--primary);
}
.quiz-question p {
    margin-bottom: 1rem;
    color: var(--text-main);
}
.quiz-options {
    list-style: none;
    padding-left: 0;
}
.quiz-options li {
    padding: 0.5rem;
    margin-bottom: 0.5rem;
    background: white;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
}
.quiz-options li:hover {
    background: #f3f4f6;
}
.quiz-options li input {
    margin-right: 0.5rem;
}
